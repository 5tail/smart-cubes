{
  "name": "maru-smartcube",
  "version": "0.0.0",
  "description": "通用智能方塊連線套件 — 讓瀏覽器（Web Bluetooth）連線 GAN / MoYu / QiYi 智能方塊",
  "type": "module",
  "license": "GPL-3.0",
  "author": "五尾（小丸號）",
  "repository": {
    "type": "git",
    "url": "https://github.com/5tail/smart-cubes.git"
  },
  "keywords": [
    "rubiks-cube",
    "smart-cube",
    "web-bluetooth",
    "gan",
    "moyu",
    "qiyi"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/web-bluetooth": "^0.0.20",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
